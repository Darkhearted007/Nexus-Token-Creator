# Backend Environment Variables
# Copy this file to .env and fill in the actual values
# ⚠️  CRITICAL: NEVER commit .env to git or Docker images

# ===== Firebase Configuration =====
# Path to Firebase service account JSON key file
# Download from Firebase Console -> Project Settings -> Service Accounts
# Store securely — this key has admin privileges
GOOGLE_APPLICATION_CREDENTIALS=/app/config/firebase-adminsdk.json
FIREBASE_PROJECT_ID=your_firebase_project_id

# ===== Solana Configuration =====
# RPC endpoint for blockchain transactions
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Commitment level for transaction confirmation
SOLANA_COMMITMENT=confirmed

# ===== Volume Bot Configuration =====
# Private key of wallet for bot trading (BASE58 encoded)
# This wallet needs SOL for gas and tokens for trading
VOLUME_BOT_PRIVATE_KEY=your_base58_encoded_private_key_here

# Tier level: 0=disabled, 1=lite, 2=pro, 3=enterprise
VOLUME_BOT_TIER=2

# Buy frequency in milliseconds
VOLUME_BOT_BUY_FREQUENCY_MS=30000

# Sell frequency in milliseconds  
VOLUME_BOT_SELL_FREQUENCY_MS=45000

# SOL amount per buy transaction
VOLUME_BOT_SOL_PER_BUY=0.5

# ===== Sniper Bot Configuration =====
# Private key for sniper wallet (BASE58 encoded)
# Separate from volume bot wallet for security
SNIPER_BOT_PRIVATE_KEY=your_sniper_base58_private_key_here

# Tier level: 0=disabled, 1=enabled
SNIPER_BOT_TIER=1

# Jito tip amount in lamports (0.000001 SOL = 1000 lamports)
JITO_TIP_LAMPORTS=100000

# Jito RPC endpoint for MEV-protected bundling
JITO_RPC_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles

# ===== Admin Configuration =====
# Private key for admin-only operations (fee withdrawal, config updates)
ADMIN_PRIVATE_KEY=your_admin_base58_private_key_here

# Public key authorized for admin operations
ADMIN_PUBLIC_KEY=your_admin_wallet_public_key

# ===== Smart Contract Configuration =====
PROGRAM_ID=5hA4DvFa82zJS6yx5ahdb2HEKvmMx4zJeXTyZaWTA5A8

# Treasury wallet that receives fees
TREASURY_WALLET=your_treasury_wallet_public_key

# ===== Firestore Configuration =====
# Collections and document names
FIRESTORE_TOKENS_COLLECTION=tokens
FIRESTORE_LAUNCHES_COLLECTION=launches
FIRESTORE_AUDIT_LOGS_COLLECTION=_audit_logs

# ===== Rate Limiting Configuration =====
# Default rate limit: 100 requests per minute
DEFAULT_RATE_LIMIT_RPM=100

# API-specific rate limits (requests per minute)
RATE_LIMIT_MINT_RPM=10
RATE_LIMIT_BOT_RPM=5
RATE_LIMIT_HEALTH_RPM=1000

# ===== Logging Configuration =====
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Audit log retention in days (0 = never delete)
AUDIT_LOG_RETENTION_DAYS=90

# ===== Security Configuration =====
# Enable/disable specific security features
RATE_LIMITING_ENABLED=true
AUDIT_LOGGING_ENABLED=true
BOT_EXECUTION_ENABLED=true

# ===== Monitoring & Health Checks =====
# Health check endpoint port
HEALTH_CHECK_PORT=3001

# Firestore connection timeout in milliseconds
FIRESTORE_TIMEOUT_MS=10000

# ===== Environment =====
NODE_ENV=production

# ===== Docker-Specific =====
# Used in docker-compose.yml for service coordination
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0
