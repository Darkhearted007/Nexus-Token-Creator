rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny for all unseen collections
    match /{document=**} {
      allow read, write: if false;
    }

    match /tokens/{tokenId} {
      // Anyone can read trending tokens
      allow read: if true;
      
      // Strict rule: Only allow token creation if the payload has correct types and constraints
      allow create: if request.resource.data.keys().hasAll(['mintAddress', 'creatorWallet', 'name', 'symbol', 'decimals', 'supply', 'hasVolumeBot', 'upvotes', 'createdAt'])
                    && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 64
                    && request.resource.data.symbol is string && request.resource.data.symbol.size() > 0 && request.resource.data.symbol.size() <= 12
                    && request.resource.data.mintAddress is string && request.resource.data.mintAddress.size() >= 32 && request.resource.data.mintAddress.size() <= 44
                    && request.resource.data.creatorWallet is string && request.resource.data.creatorWallet.size() >= 32 && request.resource.data.creatorWallet.size() <= 44
                    && request.resource.data.decimals is int && request.resource.data.decimals >= 0 && request.resource.data.decimals <= 18
                    && request.resource.data.supply is number && request.resource.data.supply > 0
                    && request.resource.data.hasVolumeBot is bool
                    && request.resource.data.upvotes == 0
                    && request.resource.data.createdAt == request.time
                    // Optional bot tiers validation
                    && (!('volumeBotTier' in request.resource.data) || request.resource.data.volumeBotTier in [0, 0.1, 0.3, 0.5])
                    && (!('sniperBotTier' in request.resource.data) || request.resource.data.sniperBotTier in [0, 0.1, 0.3, 0.5])
                    // Social links (optional strings)
                    && (!('website' in request.resource.data) || (request.resource.data.website is string && request.resource.data.website.size() <= 200))
                    && (!('twitter' in request.resource.data) || (request.resource.data.twitter is string && request.resource.data.twitter.size() <= 200))
                    && (!('telegram' in request.resource.data) || (request.resource.data.telegram is string && request.resource.data.telegram.size() <= 200));
                    
      // Only allow upvotes to increment by exactly 1; no other fields may change
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes'])
                    && request.resource.data.diff(resource.data).affectedKeys().size() == 1
                    && request.resource.data.upvotes == resource.data.upvotes + 1;
      
      allow delete: if false; // Only admin backend can delete
    }

    match /market_maker_sessions/{sessionId} {
      // Anyone can read their own session status
      allow read: if true;

      // Client may create a session in 'pending' state with required fields
      allow create: if request.resource.data.keys().hasAll(['mintAddress', 'creatorWallet', 'strategy', 'duration', 'volumeSol', 'status', 'createdAt'])
                    && request.resource.data.mintAddress is string && request.resource.data.mintAddress.size() >= 32 && request.resource.data.mintAddress.size() <= 44
                    && request.resource.data.creatorWallet is string && request.resource.data.creatorWallet.size() >= 32 && request.resource.data.creatorWallet.size() <= 44
                    && request.resource.data.strategy is string && request.resource.data.strategy.size() > 0
                    && request.resource.data.duration is number && request.resource.data.duration > 0
                    && request.resource.data.volumeSol is number && request.resource.data.volumeSol > 0
                    && request.resource.data.status == 'pending'
                    && request.resource.data.createdAt == request.time;

      // Client may only stop a session (pending or running → stopped); all other updates are admin-only
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                    && request.resource.data.status == 'stopped'
                    && (resource.data.status == 'pending' || resource.data.status == 'running');

      allow delete: if false;
    }
  }
}
